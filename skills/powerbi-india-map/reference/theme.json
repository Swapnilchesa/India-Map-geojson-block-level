        "dataLabels": [{ "fontSize": 24, "fontFamily": "Inter", "color": { "solid": { "color": "#111827" } } }],
        "categoryLabels": [{ "fontSize": 11, "fontFamily": "Inter", "color": { "solid": { "color": "#6b7280" } } }]
